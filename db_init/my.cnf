[mysqld]
# Dimension 4: Database Performance Tuning
# Calculate roughly 50-70% of available RAM. Assuming 512MB for this demo container.
innodb_buffer_pool_size = 256M

# Increase max connections to handle spikes
max_connections = 500

# Dimension 4: Database Optimization Logging
# Enable Slow Query Log to help developers identify unoptimized SQL
slow_query_log = 1
slow_query_log_file = /var/log/mysql/mariadb-slow.log
long_query_time = 2
